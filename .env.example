# SAP Coherence Checker & Evidence Gap Engine — environment configuration
#
# Copy this file to .env and populate the values for your environment.
# Never commit the populated .env file to version control (.gitignore handles this).
#
# Required keys are marked [REQUIRED].
# Optional keys improve performance or enable additional features.

# ---------------------------------------------------------------------------
# LLM API  [REQUIRED for Step 3 — endpoint coherence analysis]
# ---------------------------------------------------------------------------

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Provider switch: set to "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# ---------------------------------------------------------------------------
# NCBI / PubMed API key  [OPTIONAL but strongly recommended]
# ---------------------------------------------------------------------------
# Register free at: https://www.ncbi.nlm.nih.gov/account/
#
# Without this key: NCBI enforces a 3 requests/second rate limit.
# With this key:    Rate limit rises to 10 requests/second.
#
# For a full pipeline run (~200 trials × 3–5 PubMed requests each), an API
# key reduces the linkage step from ~20 minutes to ~6 minutes.

NCBI_API_KEY=a33cf5ec598dd7261eb0bc64826d02959908
